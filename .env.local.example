NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Daily keepalive + backup cron (/api/cron/backup)
# CRON_SECRET: any long random string; Vercel sends it as "Authorization: Bearer <value>"
CRON_SECRET=
# Fine-grained GitHub PAT scoped to ONLY the private backup repo (contents: read/write)
GITHUB_BACKUP_TOKEN=
# owner/name of the private backup repo
GITHUB_BACKUP_REPO=
